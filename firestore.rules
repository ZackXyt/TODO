rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 创作者管理员邮箱 — 仅用于读取设备元数据做聚合统计（DAU/WAU/设备分布）。
    // 最小必要原则：admin 不能读任务/清单/随想录等内容，只能读 devices 子集合。
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'zack2004221@163.com';
    }

    // 每个用户的私人数据：仅本人可读写。admin 也读不到。
    match /users/{userId}/{document=**} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 设备元数据子集合（直读路径）：本人可读写，admin 额外可读。
    // Firestore 规则对每条匹配的 match 取 OR — 上面的通配规则不给 admin 开 read，
    // 这里单独给 admin read，结果是 admin 直读 devices 文档可以，读任务/笔记不行。
    match /users/{userId}/devices/{deviceId} {
      allow read:  if request.auth != null
                    && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 设备元数据 collection group 查询：admin 跨所有用户拉 devices 做聚合。
    // collectionGroup() 只匹配带递归通配 {path=**} 的规则，普通的具体路径规则
    // 不会被命中。仅给 read，不给 write —— 写仍然走具体路径规则做本人校验。
    match /{path=**}/devices/{deviceId} {
      allow read: if isAdmin();
    }

    // 拒绝所有其他读写（默认）
  }
}
